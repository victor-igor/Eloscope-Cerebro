{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://eloscope.com/schemas/handoff-schema.json",
  "title": "Eloscope Handoff Artifact",
  "description": "Schema for inter-agent handoff artifacts. Invariante #1: handoffs são sempre artefato estruturado, nunca conversa livre.",
  "type": "object",
  "required": ["type", "from", "to", "date", "project", "payload_type", "context", "acceptance_criteria"],
  "properties": {
    "type": {
      "const": "handoff"
    },
    "from": {
      "type": "string",
      "description": "Agent id de origem (ex: orion, hefesto, minerva)"
    },
    "to": {
      "type": "string",
      "description": "Agent id de destino"
    },
    "date": {
      "type": "string",
      "format": "date",
      "description": "Data no formato YYYY-MM-DD"
    },
    "project": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$",
      "description": "Slug do projeto em kebab-case"
    },
    "payload_type": {
      "type": "string",
      "enum": [
        "discovery-report",
        "proposal-brief",
        "adr",
        "ai-contract",
        "qa-report",
        "deck-brief",
        "kickoff-doc",
        "handover-package",
        "case-study",
        "eval-report",
        "other"
      ]
    },
    "payload_path": {
      "type": "string",
      "description": "Path relativo ao artefato principal"
    },
    "context": {
      "type": "string",
      "maxLength": 500,
      "description": "Contexto em 3-5 linhas — o que gatilhou este handoff"
    },
    "acceptance_criteria": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1,
      "description": "Critérios mensuráveis para o receptor aceitar"
    },
    "deadline": {
      "type": "string",
      "format": "date",
      "description": "Prazo limite (ou 'best effort')"
    },
    "dependencies": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Bloqueios externos, contratos, inputs faltantes"
    },
    "return_condition": {
      "type": "string",
      "description": "Condição que dispara resposta do receptor"
    },
    "return_format": {
      "type": "string",
      "description": "Artefato esperado de volta (se houver)"
    }
  },
  "additionalProperties": false
}
